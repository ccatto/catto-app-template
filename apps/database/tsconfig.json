{
  "compilerOptions": {
    "composite": true,
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["*.ts", "generated/**/*.ts"],
  "exclude": ["node_modules", "dist", "prisma.config.ts"]
}
